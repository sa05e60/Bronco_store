{
  "version": 2,
  "name": "bronco-frontend",
  "public": true,
  "cleanUrls": true,
  "trailingSlash": true,
  "routes": [
    {
      "src": "^/api/(.*)$",
      "dest": "/api/$1"
    },
    {
      "src": "^/store/(.*)$",
      "dest": "/store/$1"
    },
    {
      "src": "^/admin/(.*)$",
      "dest": "/admin/$1"
    },
    {
      "src": "^/(.*)$",
      "dest": "/$1"
    }
  ]
}

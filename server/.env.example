# Database (use a free MySQL provider like Railway, PlanetScale, TiDB Cloud, or Aiven)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=bronco_db

# Server
PORT=3001

# Base URL of the frontend (used in emails for reset links, etc.)
BASE_URL=http://localhost:5500

# Email SMTP Settings (Gmail App Password required)
STORE_EMAIL=
STORE_EMAIL_PASSWORD=
STORE_EMAIL_NAME=BRONCO Store

# CORS — comma-separated allowed origins (your Vercel frontend URL)
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500
